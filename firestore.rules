rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active != false;
    }

    function validDong(dong) {
      return dong in [
        '양동', '양3동', '농성1동', '농성2동', '광천동', '유덕동',
        '치평동', '상무1동', '상무2동', '화정1동', '화정2동', '화정3동',
        '화정4동', '서창동', '금호1동', '금호2동', '풍암동', '동천동'
      ];
    }

    function validType(type) {
      return type in ['dark', 'surveillance', 'visibility', 'walking', 'anxiety', 'other'];
    }

    match /reports/{reportId} {
      allow create: if request.resource.data.keys().hasOnly([
          'dong', 'type', 'note', 'lat', 'lon', 'status', 'source', 'createdAt'
        ])
        && validDong(request.resource.data.dong)
        && validType(request.resource.data.type)
        && request.resource.data.note is string
        && request.resource.data.note.size() > 0
        && request.resource.data.note.size() <= 120
        && request.resource.data.lat is number
        && request.resource.data.lat >= 35.0
        && request.resource.data.lat <= 35.3
        && request.resource.data.lon is number
        && request.resource.data.lon >= 126.7
        && request.resource.data.lon <= 127.0
        && request.resource.data.status == 'received'
        && request.resource.data.source == 'citizen-web'
        && request.resource.data.createdAt == request.time;

      allow read: if isAdmin();

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'reviewerEmail', 'updatedAt'
        ])
        && request.resource.data.status in ['received', 'reviewing', 'reflected', 'hold']
        && request.resource.data.reviewerEmail == request.auth.token.email
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;
    }

    match /admins/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
