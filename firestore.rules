rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active != false;
    }

    function validDong(dong) {
      return dong in [
        '양동', '양3동', '농성1동', '농성2동', '광천동', '유덕동',
        '치평동', '상무1동', '상무2동', '화정1동', '화정2동', '화정3동',
        '화정4동', '서창동', '금호1동', '금호2동', '풍암동', '동천동'
      ];
    }

    function validType(type) {
      return type in ['dark', 'surveillance', 'visibility', 'walking', 'anxiety', 'other'];
    }

    match /reports/{reportId} {
      allow create: if request.resource.data.keys().hasOnly([
          'dong', 'type', 'note', 'lat', 'lon', 'status', 'source', 'createdAt'
        ])
        && validDong(request.resource.data.dong)
        && validType(request.resource.data.type)
        && request.resource.data.note is string
        && request.resource.data.note.size() > 0
        && request.resource.data.note.size() <= 120
        && request.resource.data.lat is number
        && request.resource.data.lat >= 35.0
        && request.resource.data.lat <= 35.3
        && request.resource.data.lon is number
        && request.resource.data.lon >= 126.7
        && request.resource.data.lon <= 127.0
        && request.resource.data.status == 'received'
        && request.resource.data.source == 'citizen-web'
        && request.resource.data.createdAt == request.time;

      allow read: if isAdmin();

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'dong', 'type', 'note', 'lat', 'lon', 'status',
          'reviewerEmail', 'updatedAt', 'deleted', 'deletedAt', 'deletedBy'
        ])
        && validDong(request.resource.data.dong)
        && validType(request.resource.data.type)
        && request.resource.data.note is string
        && request.resource.data.note.size() > 0
        && request.resource.data.note.size() <= 120
        && request.resource.data.lat is number
        && request.resource.data.lat >= 35.0
        && request.resource.data.lat <= 35.3
        && request.resource.data.lon is number
        && request.resource.data.lon >= 126.7
        && request.resource.data.lon <= 127.0
        && request.resource.data.status in ['received', 'reviewing', 'reflected', 'hold']
        && request.resource.data.reviewerEmail == request.auth.token.email
        && request.resource.data.updatedAt == request.time
        && (!('deleted' in request.resource.data) || request.resource.data.deleted is bool);

      allow delete: if false;
    }

    match /admins/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /mapFeatures/{featureId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.id == featureId
        && request.resource.data.type in ['return', 'alley', 'parcel', 'vending']
        && request.resource.data.geometry in ['line', 'point']
        && validDong(request.resource.data.dong)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.location is string
        && request.resource.data.location.size() <= 150
        && request.resource.data.points is list
        && request.resource.data.points.size() >= 1
        && request.resource.data.points.size() <= 500
        && ((request.resource.data.geometry == 'point' && request.resource.data.points.size() == 1)
          || (request.resource.data.geometry == 'line' && request.resource.data.points.size() >= 2))
        && request.resource.data.active is bool
        && request.resource.data.updatedAt == request.time
        && request.resource.data.updatedBy == request.auth.token.email;
      allow delete: if false;
    }

    match /mapFeatureHistory/{historyId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.editedAt == request.time
        && request.resource.data.editedBy == request.auth.token.email;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
